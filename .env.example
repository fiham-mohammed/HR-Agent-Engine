# Server configuration
HOST=127.0.0.1
PORT=8000

# SQLite Database (relative path — works on any OS)
DATABASE_URL=sqlite:///hr_automation.db

# LLM Configuration
# Set to 'mock' for offline simulation (default).
# Set to 'openai' or 'gemini' for real LLM integration.
LLM_PROVIDER=mock
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Memory Configuration
# Minimum significance score (1-10) to promote a memory to Long-Term Memory
LTM_SIGNIFICANCE_THRESHOLD=7
